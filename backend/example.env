
# Database:
DATABASE_URL=postgresql://evoting_app:AC40001@localhost:5432/evoting_db

# Encryption provider: "local" for dev, "aws_kms" for production/Learner Lab
ENCRYPTION_PROVIDER=aws_kms

# Local Fernet key (used when ENCRYPTION_PROVIDER=local)
# Generate a new key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# HMAC secret for search tokens — use a long random string (both providers)
ENCRYPTION_HMAC_SECRET=

# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are read automatically by boto3 from env
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
# KMS key ARN or alias — create via AWS Console > KMS > Customer managed keys
KMS_KEY_ID=


# JWT Auth
JWT_SECRET=
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Email
RESEND_API_KEY=
EMAIL_FROM=evoting@resend.dev

# Stripe Identity (KYC)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
