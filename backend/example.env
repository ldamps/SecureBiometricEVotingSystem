# Database:
DATABASE_URL=

# Encryption provider: "local" for dev, "aws_kms" for production/Learner Lab
ENCRYPTION_PROVIDER=

ENCRYPTION_KEY=

ENCRYPTION_HMAC_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

AWS_REGION=us-east-1

# KMS key ARN or alias — create via AWS Console > KMS > Customer managed keys
KMS_KEY_ID=

# CORS allowed origins (comma-separated). Default: http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Require requests to come through the API gateway (set true in production)
REQUIRE_GATEWAY=false

# Max request body size in bytes (default 5 MB)
MAX_REQUEST_BODY_BYTES=5242880