# Frontend environment variables (CRA requires REACT_APP_ prefix)

# API base URL – relative path so the proxy (dev) or Nginx (prod) handles routing
REACT_APP_API_BASE_URL=/api/v1

# Stripe Identity (KYC) – publishable key (pk_test_... or pk_live_...)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
